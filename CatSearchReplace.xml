<?xml version='1.0' encoding='UTF-8' ?>
<?charles serialisation-version='2.0' ?>
<rewriteSets>
  <rewriteSet>
    <active>true</active>
    <name>CatSearchReplace</name>
    <hosts>
      <locationPatterns>
        <locationMatch>
          <location>
            <protocol>http</protocol>
            <host>144.31.255.0</host>
            <port>3001</port>
            <path>/api/core/cats/search</path>
          </location>
        </locationMatch>
      </locationPatterns>
    </hosts>
    <rules>
      <rewriteRule>
        <active>true</active>
        <ruleType>7</ruleType>
        <matchValue>\{&quot;groups&quot;:\[.*\]\}</matchValue>
        <matchValueRegex>true</matchValueRegex>
        <matchResponse>true</matchResponse>
        <newValue><![CDATA[{
  "groups": [ {
      "title": "Т", "cats": [
        { "id": 999,
          "name": "CharlesCat", "description": "Подмененный результат поиска",
          "tags": "test,rewrite", "gender": "male",
          "likes": 100500, "dislikes": 0
        } ], "count": 1
    } ]
}]]></newValue>
        <caseSensitive>false</caseSensitive>
        <replaceType>1</replaceType>
      </rewriteRule>
    </rules>
  </rewriteSet>
</rewriteSets>
